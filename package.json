{
  "name": "vugola-mcp",
  "version": "1.1.3",
  "mcpName": "io.github.vcoder25/vugola-mcp",
  "description": "Official MCP server for Vugola — AI video clipping for agents.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "vugola-mcp": "dist/index.js",
    "vugola-mcp-install": "dist/install-bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
