    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "keywords": [
    "mcp",
    "vugola",
    "video",
    "clipping",
    "ai",
    "agents"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/VCoder25/vugola-mcp.git"
